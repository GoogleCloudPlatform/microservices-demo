AEGIS_RUNTIME_MODE=production
AEGIS_ENVIRONMENT=public
AEGIS_CLUSTER_NAME=online-boutique
AEGIS_ALLOWED_ORIGINS=https://your-stable-ngrok-domain.ngrok.app
AEGIS_AUTH_ENABLED=true
AEGIS_API_TOKEN=change-me-to-a-long-random-token
AEGIS_GOOGLE_OAUTH_ENABLED=false
AEGIS_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
AEGIS_SESSION_COOKIE_NAME=aegis_session
AEGIS_SESSION_COOKIE_SECURE=true
AEGIS_SESSION_TTL_SECONDS=604800
AEGIS_OPERATOR_EMAILS=your-google-email@example.com
AEGIS_ORCHESTRATOR=docker
AEGIS_MODEL_DIR=models/aegis_models
