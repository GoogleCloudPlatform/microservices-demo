{
    "swagger": "2.0",
    "info": {
        "description": "Frontend service for Google Microservices Demo.",
        "title": "Hipster Shop Frontend API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/": {
            "get": {
                "description": "Displays the Hipster Shop home page with the list of available products.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Home"
                ],
                "summary": "Home page",
                "responses": {
                    "200": {
                        "description": "Home page rendered successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/assistant": {
            "get": {
                "description": "Renders the shopping assistant interface for interacting with the AI assistant.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Assistant"
                ],
                "summary": "Display shopping assistant page",
                "responses": {
                    "200": {
                        "description": "Assistant page rendered successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/bot": {
            "post": {
                "description": "Sends a user query to the shopping assistant and returns the generated response.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Assistant"
                ],
                "summary": "Chat with shopping assistant",
                "parameters": [
                    {
                        "description": "Chat request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/cart": {
            "get": {
                "description": "Retrieves and displays the current user's shopping cart, including cart items, quantities, prices, and total amount.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Cart"
                ],
                "summary": "View shopping cart",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Coupon validation error message, set when redirected here from /cart/checkout",
                        "name": "coupon_error",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Coupon code to pre-fill in the form, set when redirected here from /cart/checkout",
                        "name": "coupon_code",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Cart page rendered successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Adds a product to the current shopping cart.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Cart"
                ],
                "summary": "Add product to cart",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Product ID",
                        "name": "product_id",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Quantity",
                        "name": "quantity",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect to cart"
                    },
                    "422": {
                        "description": "Validation Error"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    }
                }
            }
        },
        "/cart/checkout": {
            "post": {
                "description": "Processes the checkout form, validates the input, places the order using the Checkout gRPC service, and renders the order confirmation page.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Checkout"
                ],
                "summary": "Place an order",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Customer email",
                        "name": "email",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Street address",
                        "name": "street_address",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "ZIP/Postal code",
                        "name": "zip_code",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "City",
                        "name": "city",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "State",
                        "name": "state",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Country",
                        "name": "country",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Credit card number",
                        "name": "credit_card_number",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Credit card expiration month",
                        "name": "credit_card_expiration_month",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Credit card expiration year",
                        "name": "credit_card_expiration_year",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Credit card CVV",
                        "name": "credit_card_cvv",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Coupon code",
                        "name": "coupon_code",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order placed successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "302": {
                        "description": "Redirect to /cart with a coupon_error when the submitted coupon is unknown or below its minimum order amount",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/cart/empty": {
            "post": {
                "description": "Removes all items from the current user's shopping cart.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Cart"
                ],
                "summary": "Empty shopping cart",
                "responses": {
                    "200": {
                        "description": "Cart emptied successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/logout": {
            "get": {
                "description": "Logs out the current user by clearing the session and redirects to the home page.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Authentication"
                ],
                "summary": "Logout user",
                "responses": {
                    "302": {
                        "description": "Redirect to home page after logout",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/product-meta/{ids}": {
            "get": {
                "description": "Returns product metadata for one or more product IDs.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Get product metadata",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Comma-separated product IDs",
                        "name": "ids",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid product ID",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Product not found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/product/{id}": {
            "get": {
                "description": "Displays detailed information for a specific product.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "View product details",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Product ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Product page rendered successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Product not found",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/setCurrency": {
            "post": {
                "description": "Updates the user's preferred currency and refreshes the current session.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "Currency"
                ],
                "summary": "Set preferred currency",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Currency code (e.g. USD, EUR, INR)",
                        "name": "currency_code",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect after updating currency",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid currency code",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}