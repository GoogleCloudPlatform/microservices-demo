<!--
  Emits one JSON object per line to stdout, which container log collectors
  (Google Cloud Logging / Stackdriver, Fluent Bit, Vector, etc.) parse into
  structured fields. The built-in "GcpLayout.json" template maps log levels to
  the "severity" field and the message to "message", plus a millisecond
  "timestamp" and any thread-context (MDC) values — the same shape the Go
  service produced with logrus (severity / message / timestamp), and the shape
  Stackdriver's special-field handling expects.
-->
<Configuration status="WARN">
  <Appenders>
    <Console name="STDOUT" target="SYSTEM_OUT">
      <JsonTemplateLayout eventTemplateUri="classpath:GcpLayout.json"/>
    </Console>
  </Appenders>
  <Loggers>
    <!-- Quiet the noisy transport/framework loggers. -->
    <Logger name="io.grpc.netty" level="INFO"/>
    <Logger name="io.netty" level="INFO"/>
    <Logger name="sun.net" level="INFO"/>
    <Root level="INFO">
      <AppenderRef ref="STDOUT"/>
    </Root>
  </Loggers>
</Configuration>
