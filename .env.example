# Runtime mode: dev | production
AEGIS_RUNTIME_MODE=dev

# Environment metadata
AEGIS_ENVIRONMENT=local
AEGIS_CLUSTER_NAME=online-boutique

# Frontend origin allowlist for backend CORS
AEGIS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Enable auth for mutating operator endpoints
AEGIS_AUTH_ENABLED=false
AEGIS_API_TOKEN=change-me

# Orchestrator target: auto | docker | kubernetes
AEGIS_ORCHESTRATOR=auto
AEGIS_K8S_NAMESPACE=default

# Observability backends
AEGIS_PROMETHEUS_URL=http://localhost:9090
AEGIS_LOKI_URL=http://localhost:3100
AEGIS_PROMTAIL_URL=http://localhost:9080
AEGIS_JAEGER_URL=http://localhost:16686
AEGIS_GRAFANA_URL=http://localhost:3000
AEGIS_OTEL_COLLECTOR_URL=http://localhost:8889

# Model artifacts
AEGIS_MODEL_DIR=models/aegis_models

# Runtime behavior
AEGIS_REMEDIATION_COOLDOWN_S=30
AEGIS_REMEDIATION_LOCK_TIMEOUT_S=300
AEGIS_INCIDENT_MEMORY_LIMIT=5000
AEGIS_INCIDENT_MEMORY_RETENTION_DAYS=30
